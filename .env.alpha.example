# Certi_nt alpha production example.
# Copy this file to .env on the server and fill real values.
# Do not commit the real .env.

ENV=production

# Docker host data root.
# If the repository is in C:\CertiNT\app, this keeps data in C:\CertiNT\data.
CERTI_DATA_DIR=../data

# Postgres
POSTGRES_DB=certi_nt
POSTGRES_USER=certi_nt
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://certi_nt:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/certi_nt

# App security
APP_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
SETUP_TOKEN_EXPIRE_MINUTES=30

# Public/internal URLs
BACKEND_PORT=8000
FRONTEND_PORT=80
CORS_ORIGINS=http://SERVER_NAME,http://SERVER_NAME:80,http://SERVER_NAME:5173,http://SERVER_NAME:8000
VITE_API_BASE_URL=http://SERVER_NAME:8000/api
CERTI_PUBLIC_BASE_URL=http://SERVER_NAME:8000

# Mail
SMTP_HOST=smtp.company.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
MAIL_FROM_EMAIL=certi@forgialluminio.local
MAIL_FROM_NAME=CERTI_nt
MAIL_ALWAYS_CC_EMAIL=
ACQUISITION_NOTIFICATION_ADMIN_EMAIL=

# Integrations
ESOLVER_PASSWORD=CHANGE_ME_ESOLVER_PASSWORD
QUARTA_PASSWORD=CHANGE_ME_QUARTA_PASSWORD

# Export Certi -> eSolver
CERTI_EXPORT_USERNAME=Certi
CERTI_EXPORT_PASSWORD=Certi

# PDF conversion
PDF_CONVERSION_ENABLED=true
PDF_CONVERTER=libreoffice
LIBREOFFICE_BIN=/usr/bin/soffice
PDF_CONVERSION_TIMEOUT_SECONDS=120

# AI
DOCUMENT_VISION_MODEL=gpt-5.5
CERTI_OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY_OR_LEAVE_EMPTY
